# Theta Data Core Engine Configuration
# Copy to .env and fill in, or set in your shell before running.
#   source .env  (Linux/Mac)
#   . .\ENV.ps1  (Windows PowerShell)

# Theta Terminal local REST bridge (must be running separately)
THETA_HOST=127.0.0.1
THETA_PORT=25510
THETA_TIMEOUT_S=30

# Theta Data subscription tier (FREE, VALUE, STANDARD, PRO)
THETA_TIER=PRO

# Rate limiting
MAX_CONCURRENT_REQUESTS=7
REQUESTS_PER_SECOND=0  # 0 = no limit

# Sampling
INTERVAL_SECONDS=300
INTERVAL_LABEL=5m

# Greeks API conventions
THETA_RATE_TYPE=sofr
THETA_GREEKS_VERSION=latest

# Strike selection
MAX_EXPIRATIONS_PER_TICKER=3
TOP_K_STRIKES=20
STRIKE_RANGE=20

# Quality gates
MAX_REL_SPREAD=0.20
PARITY_EPSILON_REL=0.02

# Optional: PostgreSQL for ingestion logging (set DB_PASSWORD to enable)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=data_foundation
DB_USER=postgres
DB_PASSWORD=
DB_SCHEMA=greeks_silo
DB_POOL_MIN=2
DB_POOL_MAX=12